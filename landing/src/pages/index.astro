---
import '../styles/global.css'

const calLink = "https://cal.com/andres-paez/30min"
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="CURVA — Consultoría integral para empresas que necesitan orden, estructura y dirección para crecer." />
    <title>CURVA — Consultoría empresarial</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <style>
      .reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.6s cubic-bezier(0.16,1,0.3,1), transform 0.6s cubic-bezier(0.16,1,0.3,1); }
      .reveal.visible { opacity: 1; transform: translateY(0); }
      .reveal-d1 { transition-delay: 0.08s; } .reveal-d2 { transition-delay: 0.16s; }
      .reveal-d3 { transition-delay: 0.24s; } .reveal-d4 { transition-delay: 0.32s; }
      .reveal-d5 { transition-delay: 0.4s; } .reveal-d6 { transition-delay: 0.48s; }

      .card-lift { transition: transform 0.4s cubic-bezier(0.16,1,0.3,1), box-shadow 0.4s ease; }
      .card-lift:hover { transform: translateY(-3px); box-shadow: 0 12px 40px rgba(0,0,0,0.1); }

      .marquee { overflow: hidden; white-space: nowrap; }
      .marquee-track { display: inline-block; animation: scroll 25s linear infinite; }
      @keyframes scroll { to { transform: translateX(-50%); } }

      .glow-card { position: relative; overflow: hidden; }
      .glow-card::after {
        content: ''; position: absolute; inset: 0;
        background: radial-gradient(600px circle at var(--x,50%) var(--y,50%), rgba(255,255,255,0.06), transparent 40%);
        pointer-events: none; opacity: 0; transition: opacity 0.3s;
      }
      .glow-card:hover::after { opacity: 1; }

      .gradient-text { background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

      /* Carousel */
      .cases-track { display: flex; gap: 1rem; overflow-x: auto; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
      .cases-track::-webkit-scrollbar { display: none; }
      .case-card { scroll-snap-align: start; flex: 0 0 85%; max-width: 480px; }
      @media (min-width: 640px) { .case-card { flex: 0 0 45%; } }
      @media (min-width: 1024px) { .case-card { flex: 0 0 32%; } }

      .dot-active { background-color: #2563eb; }

      /* Service selector */
      .svc-dropdown {
        opacity: 0; transform: translateY(-8px) scale(0.97); pointer-events: none;
        transition: opacity 0.25s ease, transform 0.25s ease;
      }
      .svc-dropdown.open { opacity: 1; transform: translateY(0) scale(1); pointer-events: auto; }
      .svc-option { transition: background-color 0.15s ease; }
      .svc-option:hover { background-color: #f1f5f9; }

      @media (max-width: 640px) {
        .hero-h1 { font-size: 2.25rem; }
        .hero-sub { font-size: 1.75rem; }
      }
    </style>
  </head>
  <body class="bg-white text-slate-900 font-sans antialiased overflow-x-hidden">

    <!-- NAV -->
    <nav class="fixed top-0 w-full bg-white/90 backdrop-blur-md z-50 border-b border-slate-100">
      <div class="max-w-6xl mx-auto px-5 py-3.5 flex justify-between items-center">
        <a href="#" class="text-xl font-black tracking-tighter">CURVA<span class="text-accent">.</span></a>
        <div class="flex items-center gap-5">
          <a href="#servicios" class="hidden md:inline text-sm text-slate-500 hover:text-slate-900 transition-colors">Servicios</a>
          <a href="#casos" class="hidden md:inline text-sm text-slate-500 hover:text-slate-900 transition-colors">Resultados</a>
          <a href="#equipo" class="hidden md:inline text-sm text-slate-500 hover:text-slate-900 transition-colors">Equipo</a>
          <a href={calLink} target="_blank" rel="noopener" class="text-sm font-semibold bg-slate-900 text-white px-5 py-2 rounded-full hover:bg-slate-800 transition-colors">
            Conversemos
          </a>
        </div>
      </div>
    </nav>

    <!-- HERO — fills viewport -->
    <section class="relative min-h-[calc(100vh-52px)] flex flex-col justify-center px-5">
      <div class="max-w-5xl mx-auto w-full">
        <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-xs text-slate-400 mb-8">
          <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>Proyecto activo desde 2025</span>
          <span>Tec de Monterrey</span>
          <span>Global Money Week — OECD</span>
        </div>
        <h1 class="hero-h1 text-5xl sm:text-6xl lg:text-7xl font-black leading-[1.05] tracking-tight">
          Empresas que funcionan<br class="hidden sm:block"/>por esfuerzo.
        </h1>
        <p class="hero-sub mt-2 text-4xl sm:text-5xl lg:text-[4rem] font-black leading-[1.08] tracking-tight text-slate-300">
          Transformadas en empresas<br class="hidden sm:block"/>que funcionan por estructura.
        </p>
        <p class="mt-8 text-lg sm:text-xl text-slate-500 max-w-xl leading-relaxed">
          Diagnóstico, digitalización, procesos, gobernanza, cultura, liderazgo y marketing — en una sola consultoría.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row items-start gap-3">
          <a href={calLink} target="_blank" rel="noopener" class="group inline-flex items-center justify-center gap-2 text-base font-semibold bg-slate-900 text-white px-7 py-4 rounded-full hover:bg-slate-800 transition-all hover:gap-3">
            Agendar diagnóstico gratuito
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          </a>
          <!-- Dropdown: qué necesitas -->
          <div class="relative">
            <button id="svc-trigger" class="inline-flex items-center justify-center gap-2 text-base font-semibold text-slate-500 px-7 py-4 rounded-full border border-slate-200 hover:text-slate-900 hover:border-slate-400 transition-all">
              ¿Qué necesita tu empresa?
              <svg id="svc-chevron" class="w-4 h-4 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
            </button>
            <div id="svc-dropdown" class="svc-dropdown absolute left-0 top-full mt-2 w-80 bg-white rounded-2xl shadow-xl border border-slate-100 py-2 z-40">
              <a href="/servicios/diagnostico" class="svc-option px-5 py-3.5 flex items-center gap-3">
                <span class="w-9 h-9 rounded-lg bg-slate-900 flex items-center justify-center flex-shrink-0"><svg class="w-4.5 h-4.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/></svg></span>
                <div>
                  <span class="text-sm font-semibold block">Consultoría y estructura</span>
                  <span class="text-xs text-slate-400">Diagnóstico, procesos, gobernanza, cultura</span>
                </div>
              </a>
              <a href="/servicios/digitalizacion" class="svc-option px-5 py-3.5 flex items-center gap-3">
                <span class="w-9 h-9 rounded-lg bg-accent flex items-center justify-center flex-shrink-0"><svg class="w-4.5 h-4.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg></span>
                <div>
                  <span class="text-sm font-semibold block">Digitalización y automatización</span>
                  <span class="text-xs text-slate-400">ERPs, agentes IA, integraciones</span>
                </div>
              </a>
              <a href="/servicios/marketing" class="svc-option px-5 py-3.5 flex items-center gap-3">
                <span class="w-9 h-9 rounded-lg bg-slate-900 flex items-center justify-center flex-shrink-0"><svg class="w-4.5 h-4.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.34 15.84c-.688-.06-1.386-.09-2.09-.09H7.5a4.5 4.5 0 110-9h.75c.704 0 1.402-.03 2.09-.09"/></svg></span>
                <div>
                  <span class="text-sm font-semibold block">Marketing y contenido</span>
                  <span class="text-xs text-slate-400">Redes, video, marca personal</span>
                </div>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- MARQUEE -->
    <div class="py-4 bg-slate-950 text-white select-none">
      <div class="marquee">
        <span class="marquee-track text-[12px] font-medium tracking-widest uppercase text-slate-400">
          Diagnóstico&nbsp;&nbsp;/&nbsp;&nbsp;Digitalización&nbsp;&nbsp;/&nbsp;&nbsp;ERPs&nbsp;&nbsp;/&nbsp;&nbsp;Procesos&nbsp;&nbsp;/&nbsp;&nbsp;Gobernanza&nbsp;&nbsp;/&nbsp;&nbsp;Cultura&nbsp;&nbsp;/&nbsp;&nbsp;Liderazgo&nbsp;&nbsp;/&nbsp;&nbsp;Talento&nbsp;&nbsp;/&nbsp;&nbsp;Finanzas&nbsp;&nbsp;/&nbsp;&nbsp;Marketing&nbsp;&nbsp;/&nbsp;&nbsp;Automatización&nbsp;&nbsp;/&nbsp;&nbsp;Diagnóstico&nbsp;&nbsp;/&nbsp;&nbsp;Digitalización&nbsp;&nbsp;/&nbsp;&nbsp;ERPs&nbsp;&nbsp;/&nbsp;&nbsp;Procesos&nbsp;&nbsp;/&nbsp;&nbsp;Gobernanza&nbsp;&nbsp;/&nbsp;&nbsp;Cultura&nbsp;&nbsp;/&nbsp;&nbsp;Liderazgo&nbsp;&nbsp;/&nbsp;&nbsp;Talento&nbsp;&nbsp;/&nbsp;&nbsp;Finanzas&nbsp;&nbsp;/&nbsp;&nbsp;Marketing&nbsp;&nbsp;/&nbsp;&nbsp;Automatización&nbsp;&nbsp;/&nbsp;&nbsp;
        </span>
      </div>
    </div>

    <!-- SERVICIOS — 3 bloques -->
    <section id="servicios" class="py-20 sm:py-24 px-5">
      <div class="max-w-6xl mx-auto">
        <div class="reveal max-w-2xl mb-12">
          <p class="text-xs font-semibold text-accent uppercase tracking-widest mb-2">Nuestros servicios</p>
          <h2 class="text-2xl sm:text-3xl lg:text-4xl font-black tracking-tight leading-tight">¿Qué estás buscando?</h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <!-- 1. Consultoría y estructura -->
          <a href="/servicios/diagnostico" class="reveal reveal-d1 group card-lift glow-card rounded-2xl bg-slate-950 text-white p-7 sm:p-8 flex flex-col justify-between min-h-[300px]">
            <div>
              <div class="w-12 h-12 rounded-xl bg-accent/20 flex items-center justify-center mb-5">
                <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/></svg>
              </div>
              <h3 class="text-xl font-bold mb-2">Consultoría y estructura</h3>
              <p class="text-slate-400 text-sm leading-relaxed mb-5">Diagnóstico, procesos, gobernanza, cultura, liderazgo, roles. Todo lo que necesitas para que tu empresa funcione por sistema, no por esfuerzo.</p>
            </div>
            <div class="flex flex-wrap gap-1.5 mb-5">
              <span class="px-2.5 py-1 rounded-full bg-white/10 text-[11px] font-medium text-slate-300">Diagnóstico</span>
              <span class="px-2.5 py-1 rounded-full bg-white/10 text-[11px] font-medium text-slate-300">Procesos</span>
              <span class="px-2.5 py-1 rounded-full bg-white/10 text-[11px] font-medium text-slate-300">Gobernanza</span>
              <span class="px-2.5 py-1 rounded-full bg-white/10 text-[11px] font-medium text-slate-300">Cultura</span>
              <span class="px-2.5 py-1 rounded-full bg-white/10 text-[11px] font-medium text-slate-300">Liderazgo</span>
            </div>
            <span class="inline-flex items-center gap-2 text-sm font-semibold text-accent group-hover:gap-3 transition-all">
              Ver más
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
            </span>
          </a>

          <!-- 2. Digitalización y automatización -->
          <a href="/servicios/digitalizacion" class="reveal reveal-d2 group card-lift glow-card rounded-2xl bg-accent text-white p-7 sm:p-8 flex flex-col justify-between min-h-[300px]">
            <div>
              <div class="w-12 h-12 rounded-xl bg-white/20 flex items-center justify-center mb-5">
                <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
              <h3 class="text-xl font-bold mb-2">Digitalización y automatización</h3>
              <p class="text-white/75 text-sm leading-relaxed mb-5">ERPs, sistemas, agentes con IA, automatización de flujos. Herramientas que realmente se usan y transforman tu operación.</p>
            </div>
            <div class="flex flex-wrap gap-1.5 mb-5">
              <span class="px-2.5 py-1 rounded-full bg-white/15 text-[11px] font-medium text-white/80">ERPs / Odoo</span>
              <span class="px-2.5 py-1 rounded-full bg-white/15 text-[11px] font-medium text-white/80">Automatización</span>
              <span class="px-2.5 py-1 rounded-full bg-white/15 text-[11px] font-medium text-white/80">Agentes IA</span>
              <span class="px-2.5 py-1 rounded-full bg-white/15 text-[11px] font-medium text-white/80">Integraciones</span>
            </div>
            <span class="inline-flex items-center gap-2 text-sm font-semibold text-white group-hover:gap-3 transition-all">
              Ver más
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
            </span>
          </a>

          <!-- 3. Marketing y contenido -->
          <a href="/servicios/marketing" class="reveal reveal-d3 group card-lift rounded-2xl bg-slate-50 border border-slate-100 p-7 sm:p-8 flex flex-col justify-between min-h-[300px]">
            <div>
              <div class="w-12 h-12 rounded-xl bg-slate-900 flex items-center justify-center mb-5">
                <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.34 15.84c-.688-.06-1.386-.09-2.09-.09H7.5a4.5 4.5 0 110-9h.75c.704 0 1.402-.03 2.09-.09m0 9.18c.253.962.584 1.892.985 2.783.247.55.06 1.21-.463 1.511l-.657.38c-.551.318-1.26.117-1.527-.461a20.845 20.845 0 01-1.44-4.282m3.102.069a18.03 18.03 0 01-.59-4.59c0-1.586.205-3.124.59-4.59m0 9.18a23.848 23.848 0 018.835 2.535M10.34 6.66a23.847 23.847 0 008.835-2.535m0 0A23.74 23.74 0 0018.795 3m.38 1.125a23.91 23.91 0 011.014 5.395m-1.014 8.855c-.118.38-.245.754-.38 1.125m.38-1.125a23.91 23.91 0 001.014-5.395m0-3.46c.495.413.811 1.035.811 1.73 0 .695-.316 1.317-.811 1.73m0-3.46a24.347 24.347 0 010 3.46"/></svg>
              </div>
              <h3 class="text-xl font-bold mb-2">Marketing y contenido</h3>
              <p class="text-slate-500 text-sm leading-relaxed mb-5">Estrategia de marca, videos, redes sociales, marca personal. Contenido que conecta y posiciona, no que llena espacio.</p>
            </div>
            <div class="flex flex-wrap gap-1.5 mb-5">
              <span class="px-2.5 py-1 rounded-full bg-slate-200/60 text-[11px] font-medium text-slate-600">Redes sociales</span>
              <span class="px-2.5 py-1 rounded-full bg-slate-200/60 text-[11px] font-medium text-slate-600">Video</span>
              <span class="px-2.5 py-1 rounded-full bg-slate-200/60 text-[11px] font-medium text-slate-600">Marca personal</span>
              <span class="px-2.5 py-1 rounded-full bg-slate-200/60 text-[11px] font-medium text-slate-600">Estrategia</span>
            </div>
            <span class="inline-flex items-center gap-2 text-sm font-semibold text-slate-900 group-hover:gap-3 transition-all">
              Ver más
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
            </span>
          </a>
        </div>

        <!-- Bloque: 100% personalizado -->
        <div class="reveal mt-10 rounded-2xl border border-slate-200 bg-white p-8 sm:p-10">
          <div class="flex flex-col sm:flex-row gap-8">
            <div class="sm:w-1/3">
              <h3 class="text-xl sm:text-2xl font-black tracking-tight leading-snug">No eliges un paquete.<br/><span class="text-accent">Diseñamos el tuyo.</span></h3>
            </div>
            <div class="sm:w-2/3 space-y-4">
              <p class="text-slate-600 text-[15px] leading-relaxed">
                Estas tres áreas no son paquetes separados — son las piezas con las que construimos algo a tu medida. Puedes combinar lo que necesites: un diagnóstico con automatización, estructura con marketing, o las tres completas. <strong class="text-slate-900">Tú defines el alcance, nosotros lo armamos.</strong>
              </p>
              <p class="text-slate-600 text-[15px] leading-relaxed">
                Sabemos que tu empresa no puede parar. Por eso nosotros nos adaptamos a tus tiempos, a tu forma de trabajar, a tu ritmo. <strong class="text-slate-900">Nosotros entramos a tu empresa — no al revés.</strong> No te pedimos que modifiques tu operación para trabajar con nosotros. Nos integramos a lo que ya tienes y desde ahí construimos.
              </p>
              <div class="flex flex-wrap gap-3 pt-2">
                <span class="inline-flex items-center gap-1.5 text-sm text-slate-500">
                  <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>100% personalizable
                </span>
                <span class="inline-flex items-center gap-1.5 text-sm text-slate-500">
                  <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>Nos adaptamos a tus tiempos
                </span>
                <span class="inline-flex items-center gap-1.5 text-sm text-slate-500">
                  <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>Combina las áreas que quieras
                </span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CÓMO TRABAJAMOS -->
    <section class="py-20 px-5 bg-slate-950 text-white">
      <div class="max-w-5xl mx-auto">
        <div class="reveal max-w-2xl mb-12">
          <p class="text-xs font-semibold text-accent uppercase tracking-widest mb-2">Cómo trabajamos</p>
          <h2 class="text-2xl sm:text-3xl lg:text-4xl font-black tracking-tight leading-tight">No entregamos reportes.<br/><span class="text-slate-500">Construimos el cambio.</span></h2>
        </div>

        <div class="grid sm:grid-cols-4 gap-px bg-slate-800 rounded-2xl overflow-hidden">
          {[
            { num: "01", title: "Diagnóstico", desc: "Entendemos la verdad del negocio." },
            { num: "02", title: "Ruta por módulos", desc: "Primero lo urgente, luego lo estructural." },
            { num: "03", title: "Implementación", desc: "Configuramos, diseñamos, capacitamos." },
            { num: "04", title: "Acompañamiento", desc: "Hasta que el cambio se sostenga solo." },
          ].map((s, i) => (
            <div class={`reveal reveal-d${i + 1} bg-slate-950 p-7`}>
              <span class="text-3xl font-black gradient-text block mb-4">{s.num}</span>
              <h3 class="font-bold text-base mb-1.5">{s.title}</h3>
              <p class="text-slate-400 text-sm leading-relaxed">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CASOS DE ÉXITO — Carousel -->
    <section id="casos" class="py-20 sm:py-24 px-5">
      <div class="max-w-6xl mx-auto">
        <div class="reveal flex flex-col sm:flex-row sm:items-end sm:justify-between mb-10">
          <div>
            <p class="text-xs font-semibold text-accent uppercase tracking-widest mb-2">Resultados reales</p>
            <h2 class="text-2xl sm:text-3xl lg:text-4xl font-black tracking-tight leading-tight">Proyectos que hablan<br/><span class="text-slate-400">por sí solos.</span></h2>
          </div>
          <div class="flex gap-2 mt-4 sm:mt-0">
            <button id="prev-case" aria-label="Anterior" class="w-10 h-10 rounded-full border border-slate-200 flex items-center justify-center hover:border-slate-400 transition-colors">
              <svg class="w-4 h-4 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"/></svg>
            </button>
            <button id="next-case" aria-label="Siguiente" class="w-10 h-10 rounded-full border border-slate-200 flex items-center justify-center hover:border-slate-400 transition-colors">
              <svg class="w-4 h-4 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
            </button>
          </div>
        </div>

        <div id="cases-track" class="cases-track pb-4">
          <!-- CASO 1: Retail + microcréditos -->
          <div class="case-card">
            <div class="card-lift rounded-2xl border border-slate-100 bg-white p-7 h-full flex flex-col">
              <div class="flex items-center gap-2 mb-4">
