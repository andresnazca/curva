---
import '../styles/global.css'

const calLink = "https://cal.com/andres-paez/30min"
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="CURVA — Consultoría integral para empresas que necesitan orden, estructura y dirección para crecer." />
    <title>CURVA — Consultoría empresarial</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <style>
      .reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.6s cubic-bezier(0.16,1,0.3,1), transform 0.6s cubic-bezier(0.16,1,0.3,1); }
      .reveal.visible { opacity: 1; transform: translateY(0); }
      .reveal-d1 { transition-delay: 0.08s; } .reveal-d2 { transition-delay: 0.16s; }
      .reveal-d3 { transition-delay: 0.24s; } .reveal-d4 { transition-delay: 0.32s; }
      .reveal-d5 { transition-delay: 0.4s; } .reveal-d6 { transition-delay: 0.48s; }

      .card-lift { transition: transform 0.4s cubic-bezier(0.16,1,0.3,1), box-shadow 0.4s ease; }
      .card-lift:hover { transform: translateY(-3px); box-shadow: 0 12px 40px rgba(0,0,0,0.1); }

      .marquee { overflow: hidden; white-space: nowrap; }
      .marquee-track { display: inline-block; animation: scroll 25s linear infinite; }
      @keyframes scroll { to { transform: translateX(-50%); } }

      .glow-card { position: relative; overflow: hidden; }
      .glow-card::after {
        content: ''; position: absolute; inset: 0;
        background: radial-gradient(600px circle at var(--x,50%) var(--y,50%), rgba(255,255,255,0.06), transparent 40%);
        pointer-events: none; opacity: 0; transition: opacity 0.3s;
      }
      .glow-card:hover::after { opacity: 1; }

      .gradient-text { background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

      /* Carousel */
      .cases-track { display: flex; gap: 1rem; overflow-x: auto; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
      .cases-track::-webkit-scrollbar { display: none; }
      .case-card { scroll-snap-align: start; flex: 0 0 85%; max-width: 480px; }
      @media (min-width: 640px) { .case-card { flex: 0 0 45%; } }
      @media (min-width: 1024px) { .case-card { flex: 0 0 32%; } }

      .dot-active { background-color: #2563eb; }

      @media (max-width: 640px) {
        .hero-h1 { font-size: 2.25rem; }
        .hero-sub { font-size: 1.75rem; }
      }
    </style>
  </head>
  <body class="bg-white text-slate-900 font-sans antialiased overflow-x-hidden">

    <!-- NAV -->
    <nav class="fixed top-0 w-full bg-white/90 backdrop-blur-md z-50 border-b border-slate-100">
      <div class="max-w-6xl mx-auto px-5 py-3.5 flex justify-between items-center">
        <a href="#" class="text-xl font-black tracking-tighter">CURVA<span class="text-accent">.</span></a>
        <div class="flex items-center gap-5">
          <a href="#servicios" class="hidden md:inline text-sm text-slate-500 hover:text-slate-900 transition-colors">Servicios</a>
          <a href="#casos" class="hidden md:inline text-sm text-slate-500 hover:text-slate-900 transition-colors">Resultados</a>
          <a href="#equipo" class="hidden md:inline text-sm text-slate-500 hover:text-slate-900 transition-colors">Equipo</a>
          <a href={calLink} target="_blank" rel="noopener" class="text-sm font-semibold bg-slate-900 text-white px-5 py-2 rounded-full hover:bg-slate-800 transition-colors">
            Conversemos
          </a>
        </div>
      </div>
    </nav>

    <!-- HERO — compact, fits viewport -->
    <section class="relative pt-24 pb-12 sm:pt-28 sm:pb-16 px-5">
      <div class="max-w-5xl mx-auto">
        <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-xs text-slate-400 mb-6">
          <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>Proyecto activo desde 2025</span>
          <span>Tec de Monterrey</span>
          <span>Global Money Week — OECD</span>
        </div>
        <h1 class="hero-h1 text-4xl sm:text-5xl lg:text-6xl font-black leading-[1.05] tracking-tight">
          Empresas que funcionan<br class="hidden sm:block"/>por esfuerzo.
        </h1>
        <p class="hero-sub mt-1 text-3xl sm:text-4xl lg:text-[3.25rem] font-black leading-[1.08] tracking-tight text-slate-300">
          Transformadas en empresas<br class="hidden sm:block"/>que funcionan por estructura.
        </p>
        <p class="mt-6 text-base sm:text-lg text-slate-500 max-w-lg leading-relaxed">
          Diagnóstico, digitalización, procesos, gobernanza, cultura, liderazgo y marketing — en una sola consultoría.
        </p>
        <div class="mt-6 flex flex-col sm:flex-row gap-3">
          <a href={calLink} target="_blank" rel="noopener" class="group inline-flex items-center justify-center gap-2 text-sm font-semibold bg-slate-900 text-white px-6 py-3.5 rounded-full hover:bg-slate-800 transition-all hover:gap-3">
            Agendar diagnóstico gratuito
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          </a>
          <a href="#casos" class="inline-flex items-center justify-center text-sm font-semibold text-slate-500 px-6 py-3.5 rounded-full border border-slate-200 hover:text-slate-900 hover:border-slate-400 transition-all">
            Ver resultados reales
          </a>
        </div>
      </div>
    </section>

    <!-- MARQUEE -->
    <div class="py-4 bg-slate-950 text-white select-none">
      <div class="marquee">
        <span class="marquee-track text-[12px] font-medium tracking-widest uppercase text-slate-400">
          Diagnóstico&nbsp;&nbsp;/&nbsp;&nbsp;Digitalización&nbsp;&nbsp;/&nbsp;&nbsp;ERPs&nbsp;&nbsp;/&nbsp;&nbsp;Procesos&nbsp;&nbsp;/&nbsp;&nbsp;Gobernanza&nbsp;&nbsp;/&nbsp;&nbsp;Cultura&nbsp;&nbsp;/&nbsp;&nbsp;Liderazgo&nbsp;&nbsp;/&nbsp;&nbsp;Talento&nbsp;&nbsp;/&nbsp;&nbsp;Finanzas&nbsp;&nbsp;/&nbsp;&nbsp;Marketing&nbsp;&nbsp;/&nbsp;&nbsp;Automatización&nbsp;&nbsp;/&nbsp;&nbsp;Diagnóstico&nbsp;&nbsp;/&nbsp;&nbsp;Digitalización&nbsp;&nbsp;/&nbsp;&nbsp;ERPs&nbsp;&nbsp;/&nbsp;&nbsp;Procesos&nbsp;&nbsp;/&nbsp;&nbsp;Gobernanza&nbsp;&nbsp;/&nbsp;&nbsp;Cultura&nbsp;&nbsp;/&nbsp;&nbsp;Liderazgo&nbsp;&nbsp;/&nbsp;&nbsp;Talento&nbsp;&nbsp;/&nbsp;&nbsp;Finanzas&nbsp;&nbsp;/&nbsp;&nbsp;Marketing&nbsp;&nbsp;/&nbsp;&nbsp;Automatización&nbsp;&nbsp;/&nbsp;&nbsp;
        </span>
      </div>
    </div>

    <!-- SERVICIOS -->
    <section id="servicios" class="py-20 sm:py-24 px-5">
      <div class="max-w-6xl mx-auto">
        <div class="reveal max-w-2xl mb-12">
          <p class="text-xs font-semibold text-accent uppercase tracking-widest mb-2">Qué hacemos</p>
          <h2 class="text-2xl sm:text-3xl lg:text-4xl font-black tracking-tight leading-tight">Todo en una empresa está conectado.<br/><span class="text-slate-400">Así lo trabajamos.</span></h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-3">
          <div class="reveal reveal-d1 card-lift glow-card rounded-2xl bg-slate-950 text-white p-7 sm:p-8 flex flex-col justify-between min-h-[240px]">
            <div class="flex items-start justify-between">
              <div class="w-12 h-12 rounded-xl bg-accent/20 flex items-center justify-center">
                <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/></svg>
              </div>
              <span class="text-6xl font-black text-white/[0.04] leading-none">01</span>
            </div>
            <div>
              <h3 class="text-lg font-bold mb-1.5">Diagnóstico organizacional</h3>
              <p class="text-slate-400 text-sm leading-relaxed">Entendemos cómo funciona tu negocio de verdad — cómo vende, cobra, opera, decide.</p>
            </div>
          </div>
          <div class="reveal reveal-d2 card-lift glow-card rounded-2xl bg-accent text-white p-7 sm:p-8 flex flex-col justify-between min-h-[240px]">
            <div class="flex items-start justify-between">
              <div class="w-12 h-12 rounded-xl bg-white/20 flex items-center justify-center">
                <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
              <span class="text-6xl font-black text-white/10 leading-none">02</span>
            </div>
            <div>
              <h3 class="text-lg font-bold mb-1.5">Digitalización y ERPs</h3>
              <p class="text-white/75 text-sm leading-relaxed">Odoo, automatizaciones, herramientas reales. Implementamos con el equipo.</p>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
          {[
            { icon: "M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z", title: "Procesos", desc: "Flujos claros. Roles definidos." },
            { icon: "M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21", title: "Gobernanza", desc: "Decisiones con estructura." },
            { icon: "M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z", title: "Cultura y liderazgo", desc: "El lado humano del cambio." },
            { icon: "M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z", title: "Talento y roles", desc: "Cada persona sabe su rol." },
            { icon: "M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z", title: "Claridad financiera", desc: "Decisiones con datos reales." },
            { icon: "M10.34 15.84c-.688-.06-1.386-.09-2.09-.09H7.5a4.5 4.5 0 110-9h.75c.704 0 1.402-.03 2.09-.09m0 9.18c.253.962.584 1.892.985 2.783.247.55.06 1.21-.463 1.511l-.657.38c-.551.318-1.26.117-1.527-.461a20.845 20.845 0 01-1.44-4.282m3.102.069a18.03 18.03 0 01-.59-4.59c0-1.586.205-3.124.59-4.59m0 9.18a23.848 23.848 0 018.835 2.535M10.34 6.66a23.847 23.847 0 008.835-2.535m0 0A23.74 23.74 0 0018.795 3m.38 1.125a23.91 23.91 0 011.014 5.395m-1.014 8.855c-.118.38-.245.754-.38 1.125m.38-1.125a23.91 23.91 0 001.014-5.395m0-3.46c.495.413.811 1.035.811 1.73 0 .695-.316 1.317-.811 1.73m0-3.46a24.347 24.347 0 010 3.46", title: "Marketing", desc: "Estrategia, contenido, redes, video." },
          ].map((s, i) => (
            <div class={`reveal reveal-d${Math.min(i + 1, 6)} card-lift rounded-2xl bg-slate-50 p-6 min-h-[170px] flex flex-col justify-between border border-slate-100`}>
              <div class="w-10 h-10 rounded-lg bg-slate-900 flex items-center justify-center mb-4">
                <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d={s.icon}/></svg>
              </div>
              <div>
                <h3 class="font-bold text-sm mb-0.5">{s.title}</h3>
                <p class="text-slate-500 text-[13px] leading-relaxed">{s.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CÓMO TRABAJAMOS -->
    <section class="py-20 px-5 bg-slate-950 text-white">
      <div class="max-w-5xl mx-auto">
        <div class="reveal max-w-2xl mb-12">
          <p class="text-xs font-semibold text-accent uppercase tracking-widest mb-2">Cómo trabajamos</p>
          <h2 class="text-2xl sm:text-3xl lg:text-4xl font-black tracking-tight leading-tight">No entregamos reportes.<br/><span class="text-slate-500">Construimos el cambio.</span></h2>
        </div>

        <div class="grid sm:grid-cols-4 gap-px bg-slate-800 rounded-2xl overflow-hidden">
          {[
            { num: "01", title: "Diagnóstico", desc: "Entendemos la verdad del negocio." },
            { num: "02", title: "Ruta por módulos", desc: "Primero lo urgente, luego lo estructural." },
            { num: "03", title: "Implementación", desc: "Configuramos, diseñamos, capacitamos." },
            { num: "04", title: "Acompañamiento", desc: "Hasta que el cambio se sostenga solo." },
          ].map((s, i) => (
            <div class={`reveal reveal-d${i + 1} bg-slate-950 p-7`}>
              <span class="text-3xl font-black gradient-text block mb-4">{s.num}</span>
              <h3 class="font-bold text-base mb-1.5">{s.title}</h3>
              <p class="text-slate-400 text-sm leading-relaxed">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CASOS DE ÉXITO — Carousel -->
    <section id="casos" class="py-20 sm:py-24 px-5">
      <div class="max-w-6xl mx-auto">
        <div class="reveal flex flex-col sm:flex-row sm:items-end sm:justify-between mb-10">
          <div>
            <p class="text-xs font-semibold text-accent uppercase tracking-widest mb-2">Resultados reales</p>
            <h2 class="text-2xl sm:text-3xl lg:text-4xl font-black tracking-tight leading-tight">Proyectos que hablan<br/><span class="text-slate-400">por sí solos.</span></h2>
          </div>
          <div class="flex gap-2 mt-4 sm:mt-0">
            <button id="prev-case" aria-label="Anterior" class="w-10 h-10 rounded-full border border-slate-200 flex items-center justify-center hover:border-slate-400 transition-colors">
              <svg class="w-4 h-4 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"/></svg>
            </button>
            <button id="next-case" aria-label="Siguiente" class="w-10 h-10 rounded-full border border-slate-200 flex items-center justify-center hover:border-slate-400 transition-colors">
              <svg class="w-4 h-4 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
            </button>
          </div>
        </div>

        <div id="cases-track" class="cases-track pb-4">
          <!-- CASO 1: Retail + microcréditos -->
          <div class="case-card">
            <div class="card-lift rounded-2xl border border-slate-100 bg-white p-7 h-full flex flex-col">
              <div class="flex items-center gap-2 mb-4">
                <span class="px-2.5 py-1 rounded-full bg-accent/10 text-accent text-[11px] font-semibold uppercase tracking-wide">Consultoría integral</span>
              </div>
              <h3 class="text-lg font-bold mb-2">Retail y microcréditos — CDMX</h3>
              <p class="text-slate-500 text-sm leading-relaxed mb-6">De tarjetas de papel a operación digital completa. ERP, crédito digitalizado, gobernanza y estructura organizacional.</p>
              <div class="grid grid-cols-2 gap-4 mt-auto">
                <div>
                  <p class="text-2xl font-black">1,096</p>
                  <p class="text-xs text-slate-400 mt-0.5">Facturas digitalizadas</p>
                </div>
                <div>
                  <p class="text-2xl font-black">869</p>
                  <p class="text-xs text-slate-400 mt-0.5">Clientes en sistema</p>
                </div>
                <div>
                  <p class="text-2xl font-black">400+</p>
                  <p class="text-xs text-slate-400 mt-0.5">Créditos migrados</p>
                </div>
                <div>
                  <p class="text-2xl font-black">4 meses</p>
                  <p class="text-xs text-slate-400 mt-0.5">De implementación</p>
                </div>
              </div>
              <div class="mt-6 pt-5 border-t border-slate-100">
                <p class="text-sm text-slate-600 italic">"Lo que antes tomaba horas buscando en tarjetas, hoy se resuelve en segundos."</p>
              </div>
            </div>
          </div>

          <!-- CASO 2: Automatización con IA — Mensajería -->
          <div class="case-card">
            <div class="card-lift rounded-2xl border border-slate-100 bg-white p-7 h-full flex flex-col">
              <div class="flex items-center gap-2 mb-4">
                <span class="px-2.5 py-1 rounded-full bg-purple-500/10 text-purple-600 text-[11px] font-semibold uppercase tracking-wide">Automatización + IA</span>
              </div>
              <h3 class="text-lg font-bold mb-2">Agente IA para mensajería</h3>
              <p class="text-slate-500 text-sm leading-relaxed mb-6">Construimos un agente con inteligencia artificial para atención a clientes y cotización automática de envíos. Integrado al flujo real de operación de la empresa.</p>
              <div class="grid grid-cols-2 gap-4 mt-auto">
                <div>
                  <p class="text-2xl font-black">24/7</p>
                  <p class="text-xs text-slate-400 mt-0.5">Atención automatizada</p>
                </div>
                <div>
                  <p class="text-2xl font-black">Auto</p>
                  <p class="text-xs text-slate-400 mt-0.5">Cotizaciones de envío</p>
                </div>
              </div>
              <div class="mt-6 pt-5 border-t border-slate-100">
                <p class="text-sm text-slate-600 italic">"Los clientes reciben respuesta inmediata y cotización sin esperar a nadie."</p>
              </div>
            </div>
          </div>

          <!-- CASO 3: Marketing — Green Earth -->
          <div class="case-card">
            <div class="card-lift rounded-2xl border border-slate-100 bg-white p-7 h-full flex flex-col">
              <div class="flex items-center gap-2 mb-4">
                <span class="px-2.5 py-1 rounded-full bg-green-500/10 text-green-600 text-[11px] font-semibold uppercase tracking-wide">Marketing</span>
              </div>
              <h3 class="text-lg font-bold mb-2">Green Earth — Videos de marca personal</h3>
              <p class="text-slate-500 text-sm leading-relaxed mb-6">Estrategia de contenido y producción de videos de marca personal. Posicionamiento del fundador como referente en su industria.</p>
              <div class="grid grid-cols-2 gap-4 mt-auto">
                <div>
                  <p class="text-2xl font-black">Video</p>
                  <p class="text-xs text-slate-400 mt-0.5">Producción de contenido</p>
                </div>
                <div>
                  <p class="text-2xl font-black">Marca</p>
                  <p class="text-xs text-slate-400 mt-0.5">Personal del fundador</p>
                </div>
              </div>
              <div class="mt-6 pt-5 border-t border-slate-100">
                <p class="text-sm text-slate-600 italic">"Se construyó una narrativa auténtica para conectar con su audiencia."</p>
              </div>
            </div>
          </div>

          <!-- CASO 4: Redes — Natsu Life Bambú -->
          <div class="case-card">
            <div class="card-lift rounded-2xl border border-slate-100 bg-white p-7 h-full flex flex-col">
              <div class="flex items-center gap-2 mb-4">
                <span class="px-2.5 py-1 rounded-full bg-amber-500/10 text-amber-600 text-[11px] font-semibold uppercase tracking-wide">Redes sociales</span>
              </div>
              <h3 class="text-lg font-bold mb-2">Natsu Life Bambú — Manejo de redes</h3>
