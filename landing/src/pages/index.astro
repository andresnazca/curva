    <!-- SCRIPTS -->
    <script>
      // Scroll reveal
      const io = new IntersectionObserver((es) => {
        es.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
      }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
      document.querySelectorAll('.reveal').forEach(el => io.observe(el));

      // Glow cards
      document.querySelectorAll('.glow-card').forEach(c => {
        c.addEventListener('mousemove', (e) => {
          const r = c.getBoundingClientRect();
          c.style.setProperty('--x', ((e.clientX-r.left)/r.width*100)+'%');
          c.style.setProperty('--y', ((e.clientY-r.top)/r.height*100)+'%');
        });
      });

      // Dropdowns (nav + hero)
      function setupDropdown(triggerId, dropdownId, chevronId) {
        const trigger = document.getElementById(triggerId);
        const dropdown = document.getElementById(dropdownId);
        const chevron = chevronId ? document.getElementById(chevronId) : null;
        if (!trigger || !dropdown) return;

        trigger.addEventListener('click', (e) => {
          e.stopPropagation();
          const isOpen = dropdown.classList.toggle('open');
          if (chevron) chevron.style.transform = isOpen ? 'rotate(180deg)' : '';
          // Close other dropdowns
          document.querySelectorAll('.nav-dropdown.open, .svc-dropdown.open').forEach(d => {
            if (d !== dropdown) d.classList.remove('open');
          });
        });
      }
      setupDropdown('svc-trigger', 'svc-dropdown', 'svc-chevron');
      setupDropdown('nav-svc-trigger', 'nav-svc-dropdown', 'nav-svc-chevron');

      document.addEventListener('click', () => {
        document.querySelectorAll('.nav-dropdown.open, .svc-dropdown.open').forEach(d => d.classList.remove('open'));
        const c1 = document.getElementById('svc-chevron');
        const c2 = document.getElementById('nav-svc-chevron');
        if (c1) c1.style.transform = '';
        if (c2) c2.style.transform = '';
      });

      // Cases carousel
      const track = document.getElementById('cases-track');
      const cards = track.querySelectorAll('.case-card');
      const dots = document.querySelectorAll('.case-dot');
      const prevBtn = document.getElementById('prev-case');
      const nextBtn = document.getElementById('next-case');
      let current = 0;

      function scrollToCase(i) {
        current = Math.max(0, Math.min(i, cards.length - 1));
        cards[current].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
        dots.forEach((d, di) => d.classList.toggle('dot-active', di === current));
      }

      prevBtn.addEventListener('click', () => scrollToCase(current - 1));
      nextBtn.addEventListener('click', () => scrollToCase(current + 1));
      dots.forEach(d => d.addEventListener('click', () => scrollToCase(+d.dataset.index)));

      let scrollTimer;
      track.addEventListener('scroll', () => {
        clearTimeout(scrollTimer);
        scrollTimer = setTimeout(() => {
          const trackLeft = track.scrollLeft;
          let closest = 0, minDist = Infinity;
          cards.forEach((c, i) => {
            const dist = Math.abs(c.offsetLeft - trackLeft);
            if (dist < minDist) { minDist = dist; closest = i; }
          });
          current = closest;
          dots.forEach((d, di) => d.classList.toggle('dot-active', di === current));
        }, 100);
      });
      // Auto-scroll videos solo con hover
      const vShowcase = document.getElementById('video-showcase');
      if (vShowcase) {
        let vInterval = null;
        function startVScroll() {
          if (vInterval) return;
          vInterval = setInterval(() => {
            vShowcase.scrollLeft += 1;
            if (vShowcase.scrollLeft >= vShowcase.scrollWidth - vShowcase.clientWidth) {
              vShowcase.scrollLeft = 0;
            }
          }, 30);
        }
        function stopVScroll() {
          clearInterval(vInterval);
          vInterval = null;
        }
        vShowcase.addEventListener('mouseenter', startVScroll);
        vShowcase.addEventListener('mouseleave', stopVScroll);
        // En mobile: tocar activa, soltar para
        vShowcase.addEventListener('touchstart', startVScroll);
        vShowcase.addEventListener('touchend', stopVScroll);
      }

      // Auto-scroll digital showcase — pasa a siguiente con hover
      const dShowcase = document.getElementById('digital-showcase');
      if (dShowcase) {
        const dItems = dShowcase.children;
        let dIdx = 0;
        let dInterval = null;
        function nextDSlide() {
          dIdx = (dIdx + 1) % dItems.length;
          dItems[dIdx].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
        }
        dShowcase.addEventListener('mouseenter', () => {
          nextDSlide();
          dInterval = setInterval(nextDSlide, 3000);
        });
        dShowcase.addEventListener('mouseleave', () => {
          clearInterval(dInterval);
          dInterval = null;
        });
        dShowcase.addEventListener('touchstart', () => {
          nextDSlide();
          dInterval = setInterval(nextDSlide, 3000);
        });
        dShowcase.addEventListener('touchend', () => {
          clearInterval(dInterval);
          dInterval = null;
        });
      }
    </script>

