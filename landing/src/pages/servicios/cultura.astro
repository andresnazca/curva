---
import ServicioLayout from '../../layouts/ServicioLayout.astro'
---

<ServicioLayout
  title="Cultura y liderazgo"
  tagline="Cultura y liderazgo"
  headline="El cambio real pasa por las personas."
  description="Trabajamos con los líderes de tu empresa para construir una cultura que soporte el crecimiento. Liderazgo, comunicación interna, gestión del cambio, desarrollo de talento. No es coaching — es transformación organizacional acompañada."
  tags={["Desarrollo de líderes", "Gestión del cambio", "Comunicación interna", "Clima organizacional", "Definición de valores", "Talento y retención"]}
  cta="¿Tu equipo tiene la cultura para sostener el crecimiento?"
>
  <section class="px-5 pb-16">
    <div class="max-w-4xl mx-auto">
      <div class="bg-slate-50 border border-slate-100 p-8 sm:p-10 rounded-2xl">
        <p class="text-sm font-semibold text-slate-400 mb-4">Lo que trabajamos con tu equipo</p>
        <div class="grid sm:grid-cols-3 gap-6">
          <div>
            <p class="font-bold text-sm mb-1">Líderes que lideran</p>
            <p class="text-slate-500 text-sm">No solo que mandan — que inspiran, comunican y desarrollan a su gente.</p>
          </div>
          <div>
            <p class="font-bold text-sm mb-1">Cambio que se sostiene</p>
            <p class="text-slate-500 text-sm">Gestión del cambio real para que las transformaciones no se queden en el papel.</p>
          </div>
          <div>
            <p class="font-bold text-sm mb-1">Cultura con propósito</p>
            <p class="text-slate-500 text-sm">Valores que se viven, no que están pegados en la pared.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</ServicioLayout>
