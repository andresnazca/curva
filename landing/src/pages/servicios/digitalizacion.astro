---
import ServicioLayout from '../../layouts/ServicioLayout.astro'
---

<ServicioLayout
  title="Digitalización y ERPs"
  tagline="Digitalización y ERPs"
  headline="Tu operación en un solo sistema. De verdad."
  description="Implementamos ERPs (Odoo, entre otros) y herramientas digitales que realmente se usan. No solo configuramos — capacitamos, acompañamos y nos aseguramos de que el equipo lo adopte. Ventas, inventarios, cobranza, facturación: todo conectado."
  tags={["Implementación de Odoo", "Migración de datos", "Facturación electrónica", "Inventarios y almacén", "CRM y pipeline de ventas", "Capacitación al equipo", "Soporte continuo"]}
  cta="¿Quieres una operación que funcione en un solo lugar?"
>
  <section class="px-5 pb-16">
    <div class="max-w-4xl mx-auto">
      <div class="bg-slate-950 text-white p-8 sm:p-10 rounded-2xl">
        <p class="text-sm text-slate-400 mb-4">Lo que hemos logrado</p>
        <div class="grid sm:grid-cols-3 gap-8">
          <div>
            <p class="text-3xl font-black">1,096</p>
            <p class="text-sm text-slate-400 mt-1">Facturas digitalizadas en un proyecto</p>
          </div>
          <div>
            <p class="text-3xl font-black">869</p>
            <p class="text-sm text-slate-400 mt-1">Clientes migrados a sistema</p>
          </div>
          <div>
            <p class="text-3xl font-black">400+</p>
            <p class="text-sm text-slate-400 mt-1">Créditos digitalizados</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</ServicioLayout>
