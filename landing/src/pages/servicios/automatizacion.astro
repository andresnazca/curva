---
import ServicioLayout from '../../layouts/ServicioLayout.astro'
---

<ServicioLayout
  title="Automatización e IA"
  tagline="Automatización e inteligencia artificial"
  headline="Agentes de IA y automatizaciones que trabajan por ti."
  description="Construimos agentes inteligentes que atienden clientes, cotizan, responden preguntas y ejecutan tareas repetitivas. Automatizamos flujos de trabajo reales con n8n, IA y las herramientas que ya usas. No demos — soluciones en producción."
  tags={["Agentes con inteligencia artificial", "Atención automatizada 24/7", "Cotizaciones automáticas", "Flujos de trabajo con n8n", "Integración con WhatsApp", "Conexión con sistemas existentes"]}
  cta="¿Cuántas horas pierde tu equipo en tareas repetitivas?"
  color="purple"
>
  <section class="px-5 pb-16">
    <div class="max-w-4xl mx-auto">
      <div class="bg-slate-950 text-white p-8 sm:p-10 rounded-2xl">
        <p class="text-xs text-purple-400 uppercase tracking-widest mb-3">Caso real</p>
        <p class="font-bold text-lg mb-2">Agente IA para empresa de mensajería</p>
        <p class="text-sm text-slate-400 leading-relaxed mb-6">Construimos un agente con inteligencia artificial para una empresa de mensajería que atiende clientes automáticamente y genera cotizaciones de envíos al instante. Integrado al flujo real de operación.</p>
        <div class="grid sm:grid-cols-3 gap-6">
          <div>
            <p class="text-2xl font-black">24/7</p>
            <p class="text-sm text-slate-400 mt-1">Atención sin interrupciones</p>
          </div>
          <div>
            <p class="text-2xl font-black">Segundos</p>
            <p class="text-sm text-slate-400 mt-1">Tiempo de respuesta</p>
          </div>
          <div>
            <p class="text-2xl font-black">Auto</p>
            <p class="text-sm text-slate-400 mt-1">Cotizaciones de envío</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</ServicioLayout>
