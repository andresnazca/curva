---
import '../styles/global.css'

interface Props {
  title: string
  tagline: string
  headline: string
  description: string
  tags: string[]
  cta: string
  color?: string
}

const { title, tagline, headline, description, tags, cta, color = 'accent' } = Astro.props
const calLink = "https://cal.com/andres-paez/30min"
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={`CURVA — ${title}. ${tagline}`} />
    <title>{title} — CURVA</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <style>
      @keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
      .animate-in { animation: fadeUp 0.6s cubic-bezier(0.16,1,0.3,1) both; }
      .animate-d1 { animation-delay: 0.08s; }
      .animate-d2 { animation-delay: 0.16s; }
      .animate-d3 { animation-delay: 0.24s; }
      .animate-d4 { animation-delay: 0.32s; }
    </style>
  </head>
  <body class="bg-white text-slate-900 font-sans antialiased">

    <!-- NAV -->
    <nav class="fixed top-0 w-full bg-white/90 backdrop-blur-md z-50 border-b border-slate-100">
      <div class="max-w-6xl mx-auto px-5 py-3.5 flex justify-between items-center">
        <a href="/" class="text-xl font-black tracking-tighter">CURVA<span class="text-accent">.</span></a>
        <div class="flex items-center gap-5">
          <a href="/#servicios" class="hidden md:inline text-sm text-slate-500 hover:text-slate-900 transition-colors">Servicios</a>
          <a href="/#casos" class="hidden md:inline text-sm text-slate-500 hover:text-slate-900 transition-colors">Resultados</a>
          <a href="/#equipo" class="hidden md:inline text-sm text-slate-500 hover:text-slate-900 transition-colors">Equipo</a>
          <a href={calLink} target="_blank" rel="noopener" class="text-sm font-semibold bg-slate-900 text-white px-5 py-2 rounded-full hover:bg-slate-800 transition-colors">
            Conversemos
          </a>
        </div>
      </div>
    </nav>

    <!-- HERO -->
    <section class="pt-28 pb-16 sm:pt-36 sm:pb-20 px-5">
      <div class="max-w-4xl mx-auto">
        <a href="/" class="animate-in inline-flex items-center gap-2 text-sm text-slate-400 hover:text-slate-600 transition-colors mb-8">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"/></svg>
          Volver al inicio
        </a>
        <p class={`animate-in animate-d1 text-xs font-semibold uppercase tracking-widest mb-3 ${color === 'purple' ? 'text-purple-600' : 'text-accent'}`}>{tagline}</p>
        <h1 class="animate-in animate-d2 text-3xl sm:text-4xl lg:text-5xl font-black tracking-tight leading-tight mb-6">{headline}</h1>
        <p class="animate-in animate-d3 text-lg sm:text-xl text-slate-500 leading-relaxed max-w-2xl">{description}</p>
      </div>
    </section>

    <!-- TAGS -->
    <section class="px-5 pb-10">
      <div class="max-w-4xl mx-auto">
        <p class="animate-in animate-d3 text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">Qué incluye</p>
        <div class="animate-in animate-d4 flex flex-wrap gap-2">
          {tags.map(tag => (
            <span class="px-4 py-2 bg-slate-50 rounded-full text-sm font-medium text-slate-700 border border-slate-100">{tag}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- EXTRA CONTENT (slot) -->
    <slot />

    <!-- CTA -->
    <section class="py-20 sm:py-24 px-5">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl sm:text-4xl font-black tracking-tight leading-tight">{cta}</h2>
        <p class="mt-4 text-base text-slate-500 max-w-md mx-auto">30 minutos. Sin compromiso. Te decimos con honestidad si podemos ayudarte.</p>
        <a href={calLink} target="_blank" rel="noopener" class="group mt-8 inline-flex items-center gap-2 text-base font-semibold bg-slate-900 text-white px-8 py-4 rounded-full hover:bg-slate-800 transition-all hover:gap-3">
          Agendar conversación
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </a>
      </div>
    </section>

    <!-- OTROS SERVICIOS -->
    <section class="py-16 px-5 bg-slate-50 border-t border-slate-100">
      <div class="max-w-4xl mx-auto">
        <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-6">Otros servicios</p>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
          <a href="/servicios/diagnostico" class="px-4 py-3 bg-white rounded-xl text-sm font-medium text-slate-700 border border-slate-100 hover:border-slate-300 transition-colors">Diagnóstico</a>
          <a href="/servicios/digitalizacion" class="px-4 py-3 bg-white rounded-xl text-sm font-medium text-slate-700 border border-slate-100 hover:border-slate-300 transition-colors">Digitalización y ERPs</a>
          <a href="/servicios/procesos" class="px-4 py-3 bg-white rounded-xl text-sm font-medium text-slate-700 border border-slate-100 hover:border-slate-300 transition-colors">Procesos</a>
          <a href="/servicios/gobernanza" class="px-4 py-3 bg-white rounded-xl text-sm font-medium text-slate-700 border border-slate-100 hover:border-slate-300 transition-colors">Gobernanza</a>
          <a href="/servicios/cultura" class="px-4 py-3 bg-white rounded-xl text-sm font-medium text-slate-700 border border-slate-100 hover:border-slate-300 transition-colors">Cultura y liderazgo</a>
          <a href="/servicios/marketing" class="px-4 py-3 bg-white rounded-xl text-sm font-medium text-slate-700 border border-slate-100 hover:border-slate-300 transition-colors">Marketing</a>
          <a href="/servicios/automatizacion" class="px-4 py-3 bg-white rounded-xl text-sm font-medium text-slate-700 border border-slate-100 hover:border-slate-300 transition-colors">Automatización e IA</a>
        </div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="py-6 px-5 border-t border-slate-100">
      <div class="max-w-6xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-2">
        <a href="/" class="text-lg font-black tracking-tighter">CURVA<span class="text-accent">.</span></a>
        <p class="text-xs text-slate-400">Consultoría empresarial — Ciudad de México</p>
      </div>
    </footer>

  </body>
</html>
